# Copy this file to .env and fill in your values before starting the app.

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=200

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URL)
CORS_ORIGINS=http://localhost:9090

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Access tokens expire after this many hours (default 8 = one work day)
ACCESS_TOKEN_EXPIRE_HOURS=8

# Seed admin account — created automatically on first startup if no users exist.
# Change these before going public, then manage users via the API.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
