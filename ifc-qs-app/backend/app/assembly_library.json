{
  "version": 1,
  "notes": [
    "Each assembly defines a 'match' criteria (AND logic) and a list of 'components'.",
    "All matching assemblies apply to an element — design recipes to be non-overlapping.",
    "Formula variables: area (m²), length (m), volume (m³), count (nr), weight (kg).",
    "Allowed functions in formulas: round(), ceil(), floor(), max(), min().",
    "Match criteria keys:",
    "  ifc_type          — exact IFC class string",
    "  ifc_type_in       — list of IFC class strings (any match)",
    "  is_external       — boolean",
    "  material_contains — case-insensitive substring in material field",
    "  type_name_contains — case-insensitive substring in type_name field"
  ],
  "assemblies": [
    {
      "id": "ext_wall_weatherboard",
      "label": "External Weatherboard Wall",
      "match": {
        "ifc_type_in": [
          "IfcWall",
          "IfcWallStandardCase"
        ],
        "is_external": true,
        "material_contains": "weatherboard"
      },
      "components": [
        {
          "code": "CLG-WB-150",
          "name": "Weatherboard 150mm",
          "unit": "m²",
          "formula": "area * 1.10",
          "notes": "10% waste factor"
        },
        {
          "code": "BLD-WRP",
          "name": "Building wrap",
          "unit": "m²",
          "formula": "area * 1.05",
          "notes": "5% laps and waste"
        },
        {
          "code": "BTN-45x45",
          "name": "Vertical batten 45×45mm",
          "unit": "lm",
          "formula": "area * 4.2",
          "notes": "At 250mm centres"
        },
        {
          "code": "SCW-50-8G",
          "name": "Cladding screw 50mm 8g stainless",
          "unit": "nr",
          "formula": "round(area * 12)",
          "notes": "~12 per m²"
        }
      ]
    },
